{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI IDE Desktop",
  "version": "0.1.0",
  "identifier": "com.openai.ai-ide-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI IDE Desktop",
        "width": 1540,
        "height": 980,
        "minWidth": 1160,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
