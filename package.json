{
  "name": "fortshell",
  "version": "1.0.5",
  "description": "Terminal-first multi AI CLI management IDE",
  "main": "dist-main/index.js",
  "scripts": {
    "dev": "concurrently -n vite,tsc,electron \"vite --config vite.config.ts\" \"tsc -w\" \"node scripts/wait-and-launch.mjs\"",
    "build:main": "tsc",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "package": "npm run build && electron-builder --config.mac.identity=null",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac --config.mac.identity=null",
    "package:mac:all": "npm run build && electron-builder --mac --config.mac.identity=null",
    "package:linux": "npm run build && electron-builder --linux",
    "rebuild": "npx electron-rebuild -f -w node-pty",
    "postinstall": "patch-package",
    "postpackage": "npx electron-rebuild -f -w node-pty"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "build": {
    "appId": "com.fortshell.app",
    "productName": "FortShell",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-main/**/*",
      "dist-renderer/**/*",
      "native/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "native/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "zip",
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ignore": "^7.0.5",
    "node-addon-api": "^8.6.0",
    "node-pty": "^1.1.0",
    "patch-package": "^8.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
